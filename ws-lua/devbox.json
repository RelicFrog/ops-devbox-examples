{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "env": {
    "C_DBX_META_TEAM":             "RelicFrog",
    "C_DBX_META_PROJECT_ID":       "ops-devbox-examples/ws-lua",
    "C_DBX_META_VERSION":          "1",
    "PATH":                        "$PATH:$PWD/bin",
    "POWERLEVEL9K_INSTANT_PROMPT": "quiet"
  },
  "shell": {
    "init_hook": [
      "scripts/devbox/dbx_init.sh",
      "pre-commit install --install-hooks 2>/dev/null || true"
    ],
    "scripts": {
      "build": ["make build"],
      "check": ["make check"],
      "fmt":   ["make fmt"],
      "lint":  ["make lint"],
      "test":  ["make test"],
      "clean": ["make clean"],
      "run":   ["luajit src/main.lua \"$@\""],
      "info": [
        "echo '--- ws-lua devbox workspace ---'",
        "echo \"LuaJIT:      $(luajit -v 2>/dev/null | head -1 || echo 'not available')\"",
        "echo \"luacheck:    $(luacheck --version 2>/dev/null || echo 'not available')\"",
        "echo \"stylua:      $(stylua --version 2>/dev/null || echo 'not available')\"",
        "echo \"Make:        $(make --version 2>/dev/null | head -1 || echo 'not available')\"",
        "echo \"Git:         $(git --version)\"",
        "echo \"Platform:    $(uname -ms)\""
      ],
      "docs": ["glow --pager README.md"]
    }
  },
  "packages": {
    "luajit":                 "2.1.1774638290",
    "lua51Packages.luacheck": "1.2.0-1",
    "stylua":                 "2.5.2",
    "git":                    "2.54.0",
    "gh":                     "2.52.0",
    "jq":                     "1.8.1",
    "curl":                   "8.17.0",
    "ripgrep":                "14.1.0",
    "fd":                     "10.4.2",
    "bat":                    "0.24.0",
    "glow":                   "2.1.2",
    "gitleaks":               "8.30.1",
    "gnumake":                "4.4.1",
    "pre-commit":             "4.5.1"
  }
}
