{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED":        "1",
    "PATH":                   "$PATH:$PWD/bin",
    "C_DBX_META_TEAM":        "RelicFrog",
    "C_DBX_META_PROJECT_ID":  "ops-devbox-examples/ws-python",
    "C_DBX_META_VERSION":     "1",
    "POWERLEVEL9K_INSTANT_PROMPT": "quiet"
  },
  "shell": {
    "init_hook": [
      "scripts/devbox/dbx_init.sh",
      "pre-commit install --install-hooks 2>/dev/null || true"
    ],
    "scripts": {
      "build": ["make build"],
      "check": ["make check"],
      "fmt":   ["make fmt"],
      "lint":  ["make lint"],
      "test":  ["make test"],
      "audit": ["make audit"],
      "clean": ["make clean"],
      "run":   ["python -m primes_cli \"$@\""],
      "info": [
        "echo '--- ws-python devbox workspace ---'",
        "echo \"Python:      $(python --version 2>/dev/null || echo 'not available')\"",
        "echo \"Python path: $(which python 2>/dev/null || echo 'not available')\"",
        "echo \"ruff:        $(ruff --version 2>/dev/null || echo 'not available')\"",
        "echo \"mypy:        $(mypy --version 2>/dev/null || echo 'not available')\"",
        "echo \"pytest:      $(pytest --version 2>/dev/null || echo 'not available')\"",
        "echo \"uv:          $(uv --version 2>/dev/null || echo 'not available')\"",
        "echo \"Make:        $(make --version 2>/dev/null | head -1 || echo 'not available')\"",
        "echo \"Git:         $(git --version)\"",
        "echo \"Platform:    $(uname -ms)\""
      ],
      "docs": ["glow --pager README.md"]
    }
  },
  "packages": {
    "python":                        "3.13.3",
    "python313Packages.pytest":      "9.0.3",
    "python313Packages.pytest-cov":  "latest",
    "ruff":                          "0.15.17",
    "mypy":                          "1.20.1",
    "uv":                            "0.11.19",
    "git":                           "2.54.0",
    "gh":                            "2.52.0",
    "jq":                            "1.8.1",
    "curl":                          "8.17.0",
    "ripgrep":                       "14.1.0",
    "fd":                            "10.4.2",
    "bat":                           "0.24.0",
    "glow":                          "2.1.2",
    "gitleaks":                      "8.30.1",
    "gnumake":                       "4.4.1",
    "pre-commit":                    "4.5.1"
  }
}
