#!/usr/bin/env bash
# Copyright 2026 TEAM RelicFrog — Apache-2.0
#
# ws-k8s/bin/primes-rust
#
# kubectl exec wrapper — runs primes-cli inside the primes-rust pod.
# Transparent pass-through: all arguments forwarded to /primes-cli.
#
# Usage (inside devbox shell):
#   primes-rust check 97
#   primes-rust list --to 50
#   primes-rust nth 100

set -euo pipefail

NS="primes-workshop"
LABEL="app=primes-rust"
BINARY="/primes-cli"

pod="$(kubectl get pod \
  --namespace "${NS}" \
  --selector "${LABEL}" \
  --field-selector status.phase=Running \
  -o jsonpath='{.items[0].metadata.name}' 2>/dev/null)"

if [[ -z "${pod}" ]]; then
  echo "error: no running primes-rust pod found in namespace '${NS}'" >&2
  echo "  Run: make deploy-rust  (from ws-k8s/)" >&2
  exit 1
fi

exec kubectl exec \
  --namespace "${NS}" \
  --stdin=false \
  --tty=false \
  "${pod}" \
  -- "${BINARY}" "$@"
