#!/usr/bin/env bash
# ws-k8s/bin/primes-python — kubectl exec wrapper
set -euo pipefail
NS="primes-workshop"
pod="$(kubectl get pod --namespace "${NS}" --selector app=primes-python \
  --field-selector status.phase=Running \
  -o jsonpath='{.items[0].metadata.name}' 2>/dev/null)"
if [[ -z "${pod}" ]]; then
  echo "error: no running primes-python pod in namespace '${NS}'" >&2
  echo "  Run: make deploy-python  (from ws-k8s/)" >&2
  exit 1
fi
exec kubectl exec --namespace "${NS}" --stdin=false --tty=false \
  "${pod}" -- /usr/local/bin/primes-cli "$@"
