#!/usr/bin/env bash
# ws-rust/bin/primes-cli — wrapper for the compiled Rust binary.
# Builds automatically if the binary is missing (make build).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BINARY="${SCRIPT_DIR}/../target/release/primes-cli"

if [[ ! -x "${BINARY}" ]]; then
  echo "primes-cli: binary not found — running make build..." >&2
  make -C "${SCRIPT_DIR}/.." build >&2 || exit 1
fi

exec "${BINARY}" "$@"
